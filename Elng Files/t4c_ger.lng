<Add 99/09/28> ID( 7199 ) "{Die} {Sonne} {ist} {noch} {nicht} {aufgegangen.}"
<Add 99/09/28> ID( 7200 ) "{Die} {Sonne} {ist} {noch} {nicht} {aufgegangen.}"
