////////////////////////////// GENERAL SERVER MESSAGES //////////////////////////////
ID( 1 ) "Ihr seid nicht stark genug, um diesen Gegenstand zu benutzen."
ID( 11405 ) "Ihr habt nicht die nötigen Angriffsfertigkeiten, um diesen Gegenstand zu benutzen."
ID( 2 )	"Euer %s öffnet das Schloss."
ID( 3 )	"Ihr schafft es, das Schloss zu knacken."
ID( 4 )	"Die Türe ist verschlossen."
ID( 5 )	"Euer %s passt - %s wurde aufgeschlossen!"
ID( 6 )	"%s ist verschlossen."
ID( 7 )	"%s ist leer."
ID( 8 )  "Ihr habt nicht die nötige Ausdauer, um diesen Gegenstand zu benutzen."
ID( 9 ) "Ihr habt bereits einen Gegenstand in Eurer Ausrüstung."
ID( 10 ) "Ihr tragt bereits zwei Ringe."
ID( 11 ) "Ihr könnt nicht mit zwei Waffen gleichzeitig kämpfen."
ID( 12 ) "Ihr habt an dieser Stelle bereits einen Gegenstand in Eurer Ausrüstung."
ID( 13 ) "Ihr habt bereits einen ähnlichen Gegenstand in Eurer Ausrüstung."
ID( 14 ) "Eine merkwürdige, magische Kraft hält Euch plötzlich von einem Angriff ab."
ID( 15 ) "Ihr habt nicht die nötige Intelligenz, um diesen Gegenstand zu benutzen."
ID( 16 ) "Euer Juwel des Schicksals teleportiert Euch auf magische Weise fort, kurz bevor Euch der letzte Angriff Eures Gegners zu töten vermag."
ID( 17 ) "Ihr könnt nicht noch mehr tragen."
ID( 18 ) "Ihr seid geistig zu erschöpft, um einen weiteren Zauber anzuwenden."
ID( 19 ) "Ihr habt nicht genug Mana, um diesen Zauber anzuwenden."
ID( 20 ) "Ihr habt nicht genug Geld."
ID( 21 ) "Euch fehlt das nötige Verständnis der Dinge, um diesen Gegenstand zu benutzen."
ID( 22 ) "Eine große Macht umgibt diesen Ort und hindert Euch an einem Angriff."
ID( 23 ) "Ihr könnt diese Fähigkeit nur gegen andere Spieler einsetzen."
ID( 24 ) "Ihr seid zu weit von Eurem Opfer entfernt."
ID( 25 ) "Der Spieler wurde nicht gefunden." // Rob failed message
ID( 26 ) "Ihr habt es nicht geschafft, den Spieler zu bestehlen."
ID( 27 ) "Ihr habt den Spieler erfolgreich bestohlen!"
ID( 28 ) "Der Spieler hat keinen solchen Gegenstand dabei."
ID( 29 ) "Eine merkwürdige Kraft verhindert, dass Ihr diesen Gegenstand nehmen könnt."
ID( 30 ) "Ihr spürt, wie jemand in Euren Habseligkeiten herumzuschnüffeln versucht."
ID( 31 ) "Ihr findet einfach keine diskrete Möglichkeit, einen Blick in die Sachen dieses Spielers zu werfen."
ID( 32 ) "Wieviele Goldmünzen wollt Ihr auf den neuen Haufen legen?"
ID( 33 ) "Goldmünzen"
ID( 34 ) "Ihr müsst eine gültige Anzahl von Goldmünzen angeben."
ID( 35 ) "So viele Goldmünzen liegen in diesem Haufen gar nicht."
ID( 36 ) "Eine starke, magische Kraft hält Eure flinken Finger plötzlich von dem Gegenstand fern."
ID( 37 ) "Ihr seid im Moment etwas überladen und könnt nur einige der Gegenstände kaufen."
ID( 38 ) "Ihr habt nicht genug Gold, um diese Fähigkeit zu erlernen."
ID( 39 ) "Ihr habt nicht genug Gold, um diesen Zauber zu erlernen."
ID( 40 ) "Ihr habt nicht genug Lernpunkte, um diese Fähigkeit zu erlernen."
ID( 41 ) "Systemmeldung: Der Server wird in"
ID( 42 ) "Minuten heruntergefahren."
ID( 43 ) "Systemmeldung: Der Server wird JETZT heruntergefahren!"
ID( 44 ) "Systemmeldung: Ähm... der Server wird doch nicht runtergefahren!"
ID( 451 ) "Tut mir leid, aber der Server ist derzeit ausgelastet. Bitte versucht es in ein paar Minuten noch einmal."
ID( 452 ) "Euer Account ist gesperrt."
ID( 453 ) "Willkommen bei 'Die 4. Offenbarung'!"
ID( 454 ) "Der Spieler ist bereits online."
ID( 455 ) "Server konnte Spielerinformationen nicht laden."
ID( 456 ) "Server konnte Spielerinformationen nicht anlegen und laden."
ID( 457 ) "Ihr habt keinen Spielerzugriff auf 'Die 4. Offenbarung'."
ID( 458 ) "Verbindung abgelehnt (falsches Passwort vielleicht?)"
ID( 459 ) "Authentifizierungsserver nicht gefunden. Zugang konnte nicht bestätigt werden."
ID( 460 ) "Zugang konnte vom Authentifizierungsserver nicht bestätigt werden."
ID( 461 ) "Ungültiger Spielername."
ID( 462 ) "Spieler nicht bekannt oder gesperrt."
ID( 463 ) "Eine starke, magische Kraft verwirrt Euren Verstand und hält Euch davon ab, diesen Zauber einzusetzen."
ID( 467 ) "Ihr könnt jetzt nicht rufen. Wartet ein wenig, und dann versucht es einfach noch einmal."
ID( 468 ) "Der Weg ist versperrt."
ID( 469 ) "Ihr seid zu weit entfernt, um diesen Gegenstand zu benutzen."
ID( 470 ) "Ihr könnt nicht auf dieses Wesen zielen."
ID( 471 ) "Zu Eurer Ausrüstung dürfen keine zwei Gegenstände der gleichen Art gehören."
ID( 2776 ) "Ihr seid im Moment zu erschöpft, um Euch zu bewegen."
ID( 2777 ) "Ihr müsst ein wenig warten, bevor Ihr wieder jemandem etwas zuflüstern könnt."
ID( 2778 ) "Ihr konntet Euch kein Gold schnappen."
ID( 2841 ) "Eure Erfahrungsstufe ist noch zu niedrig, um eine Gruppe zu gründen."
ID( 2842 ) "Ihr könnt nur Spieler-Figuren in Eure Gruppe einladen."
ID( 2843 ) "Der Spieler, den Ihr einladen wollt, gehört bereits einer anderen Gruppe an."
ID( 2844 ) "Ihr seid jetzt ein Mitglied von %ss Gruppe."
ID( 2845 ) "Euer Account ist bereits in einen Server eingeloggt."
ID( 2846 ) "Einloggen läuft"
ID( 2847 ) "Ihr müsst einen Augenblick warten, bevor Ihr diese Handlung erneut durchführen könnt."
ID( 7125 ) "Spieler %s will derzeit nicht mit Flüstern gestört werden."
ID( 7126 ) "Euer Karma ist soeben gestiegen!"
ID( 7127 ) "Euer Karma ist soeben gesunken."
ID( 7171 ) "Euer Rufen wurde unterbunden, bitte wendet Euch an einen GM."
ID( 7172 ) "Euer Flüstern wurde unterbunden, bitte wendet Euch an einen GM."
ID( 7205 ) "%s zerfällt zu Staub."
ID( 7247 ) "So etwas könnt Ihr nicht in die Hand nehmen."
ID( 7254 ) "Ihr konntet den Gegenstand nicht verstecken."
ID( 7255 ) "Ihr habt Euch gut versteckt!"
ID( 7256 ) "So etwas könnt Ihr nicht verstecken."
ID( 7257 ) "Ihr habt den Gegenstand gut versteckt!"
ID( 7258 ) "Ihr habt etwas gefunden!"
ID( 7259 ) "Ihr durchsucht das Gebiet und findet nichts."
ID( 7260 ) "%s: Diesen Gegenstand könnt Ihr nicht wegwerfen."

